{
  "expo": {
    "name": "budie.",
    "slug": "budie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bevanshajan.budie",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bevanshajan.budie",
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d8936943-cde6-47cb-8659-9ffa9231a3fb"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow budie. to access your photos to update your profile picture.",
          "cameraPermission": "Allow budie. to use your camera to take profile pictures."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "d8936943-cde6-47cb-8659-9ffa9231a3fb"
      }
    },
    "owner": "shajanbevan"
  }
}
